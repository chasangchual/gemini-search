# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Google Drive (optional)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_DRIVE_FILE_IDS=fileId1,fileId2,fileId3
GOOGLE_DRIVE_FOLDER_IDS=folderId1,folderId2

# Web app
WEB_HOST=127.0.0.1
WEB_PORT=8000
SECRET_KEY=your-secret-key-for-session-cookies